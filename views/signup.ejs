<!DOCTYPE html>
<html>

<head>
  <title>Sign Up</title>
  <link rel='stylesheet' href='/stylesheets/style.css' />
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>

<body>
  <header>
    <h1>Chat Board</h1>
    <nav class="with-buttons">
      <a href="/">Home</a>
      <a href="/login">Login</a>
    </nav>
  </header>

  <div class="form-container">
    <h1>Sign Up</h1>
    <form id="signup-form" action="/signup" method="post">
      <div class="form-group">
        <label for="username">Username:</label>
        <input type="text" id="username" name="username" required>
      </div>
      <div class="form-group">
        <label for="password">Password:</label>
        <input type="password" id="password" name="password" required>
      </div>
      <% if (message) { %>
        <p class="error">
          <%= message %>
        </p>
      <% } %>
      <% if (errors) { %>
        <% errors.forEach(error => { %>
          <p class="error">
            <%= error.msg %>
          </p>
        <% }) %>
      <% } %>
      <input type="hidden" id="publicKey" name="publicKey">
      <div class="form-actions">
        <button type="submit">Sign Up</button>
      </div>
    </form>
    <div class="sign-login-button">
      <p>Already have an account?</p>
      <button><a href="/login">Login</a></button>
    </div>
  </div>

  <script>
    const toBase64 = (buffer) => btoa(String.fromCharCode(...new Uint8Array(buffer)));

    async function exportPublicKey(spkiKey) {
      const exported = await crypto.subtle.exportKey('spki', spkiKey);
      return toBase64(exported);
    }

    async function exportPrivateKey(pkcs8Key) {
      const exported = await crypto.subtle.exportKey('pkcs8', pkcs8Key);
      return toBase64(exported);
    }

    async function ensureKeyPairForUser(username) {
      const safeUsername = username.trim().toLowerCase();
      const privateKeyStorageKey = `chat_private_key_${safeUsername}`;
      const publicKeyStorageKey = `chat_public_key_${safeUsername}`;

      const existingPublicKey = localStorage.getItem(publicKeyStorageKey);
      const existingPrivateKey = localStorage.getItem(privateKeyStorageKey);
      if (existingPublicKey && existingPrivateKey) {
        return existingPublicKey;
      }

      const keyPair = await crypto.subtle.generateKey(
        {
          name: 'RSA-OAEP',
          modulusLength: 2048,
          publicExponent: new Uint8Array([1, 0, 1]),
          hash: 'SHA-256'
        },
        true,
        ['encrypt', 'decrypt']
      );

      const publicKey = await exportPublicKey(keyPair.publicKey);
      const privateKey = await exportPrivateKey(keyPair.privateKey);

      localStorage.setItem(publicKeyStorageKey, publicKey);
      localStorage.setItem(privateKeyStorageKey, privateKey);

      return publicKey;
    }

    document.getElementById('signup-form').addEventListener('submit', async (event) => {
      const username = document.getElementById('username').value;
      const publicKeyInput = document.getElementById('publicKey');

      if (!username || !window.crypto || !window.crypto.subtle) {
        return;
      }

      event.preventDefault();

      try {
        publicKeyInput.value = await ensureKeyPairForUser(username);
        event.target.submit();
      } catch (error) {
        console.error('Key generation failed:', error);
        alert('Could not initialize end-to-end encryption keys. Please try again.');
      }
    });
  </script>
</body>

</html>